{
  "name": "openclaude-sidebar",
  "displayName": "OpenClaude",
  "description": "Open Claude-style OpenClaude CLI in a Cursor/VS Code sidebar",
  "version": "0.1.0",
  "publisher": "local",
  "private": true,
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:openclaude.sidebar",
    "onCommand:openclaude.open"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "openclaude.open",
        "title": "OpenClaude: Open Sidebar",
        "icon": {
          "light": "resources/icon-mono.svg",
          "dark": "resources/icon-mono.svg"
        }
      },
      {
        "command": "openclaude.restart",
        "title": "OpenClaude: Restart Session",
        "icon": "$(refresh)"
      },
      {
        "command": "openclaude.openEditor",
        "title": "OpenClaude: Open in Editor",
        "icon": {
          "light": "resources/icon-mono.svg",
          "dark": "resources/icon-mono.svg"
        }
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "openclaude",
          "title": "OpenClaude",
          "icon": "resources/icon-mono.svg"
        }
      ]
    },
    "views": {
      "openclaude": [
        {
          "type": "webview",
          "id": "openclaude.sidebar",
          "name": "OpenClaude",
          "icon": "resources/icon-mono.svg",
          "retainContextWhenHidden": true
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "openclaude.restart",
          "when": "view == openclaude.sidebar",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "openclaude.openEditor",
          "group": "navigation@100"
        }
      ]
    },
    "configuration": {
      "title": "OpenClaude",
      "properties": {
        "openclaude.command": {
          "type": "string",
          "default": "openclaude",
          "description": "Shell command used to launch OpenClaude"
        },
        "openclaude.args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Extra arguments passed to the OpenClaude command"
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "npm run build -- --watch",
    "package": "npm run build && npx --yes @vscode/vsce package --no-dependencies --allow-missing-repository"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.25.1",
    "typescript": "^5.8.2"
  }
}
