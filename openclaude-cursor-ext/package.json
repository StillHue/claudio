{
  "name": "claudio-sidebar",
  "displayName": "Claudio",
  "description": "Claudio CLI in Cursor/VS Code — Activity Bar icon and full editor tab",
  "version": "0.1.0",
  "publisher": "local",
  "private": true,
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:claudio.sidebar",
    "onCommand:claudio.open"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudio.open",
        "title": "Claudio: Open Sidebar",
        "icon": {
          "light": "resources/icon-mono.svg",
          "dark": "resources/icon-mono.svg"
        }
      },
      {
        "command": "claudio.restart",
        "title": "Claudio: Restart Session",
        "icon": "$(refresh)"
      },
      {
        "command": "claudio.openEditor",
        "title": "Claudio: Open in Editor",
        "icon": {
          "light": "resources/icon-mono.svg",
          "dark": "resources/icon-mono.svg"
        }
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudio",
          "title": "Claudio",
          "icon": "resources/icon-mono.svg"
        }
      ]
    },
    "views": {
      "claudio": [
        {
          "type": "webview",
          "id": "claudio.sidebar",
          "name": "Claudio",
          "icon": "resources/icon-mono.svg",
          "retainContextWhenHidden": true
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "claudio.restart",
          "when": "view == claudio.sidebar",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "claudio.openEditor",
          "group": "navigation@100"
        }
      ]
    },
    "configuration": {
      "title": "Claudio",
      "properties": {
        "claudio.command": {
          "type": "string",
          "default": "claudio",
          "description": "Shell command used to launch Claudio"
        },
        "claudio.args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Extra arguments passed to the Claudio command"
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "npm run build -- --watch",
    "package": "npm run build && npx --yes @vscode/vsce package --no-dependencies --allow-missing-repository"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.25.1",
    "typescript": "^5.8.2"
  }
}
