# Dependencies & build artifacts
**/node_modules/
**/dist/
**/build/
**/*.tsbuildinfo
**/.turbo/
**/.cache/
*.vsix
**/*.vsix

# Environment & secrets — never commit
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example
**/auth.json
**/*credentials.json
**/.openclaude-profile.json
**/.openclaude/
**/.claude/
**/secrets/
**/*.pem
**/*.p12
**/*.pfx
**/id_rsa
**/id_rsa.pub
**/id_ed25519
**/id_ed25519.pub

# Local IDE / OS
.DS_Store
Thumbs.db
Desktop.ini
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
*.swo

# Logs / coverage / temp
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
coverage/
.nyc_output/
.tmp/
.tmp-*/
temp_reference/
reports/
# Local scratch at repo root only — do NOT ignore openclaude-fork/src/commands/plan/
/plan/
__pycache__/
*.py[cod]
.pytest_cache/
.worktrees/
agent.log

# Package manager / local agent docs (fork)
openclaude-fork/package-lock.json
openclaude-fork/GEMINI.md
openclaude-fork/CLAUDE.md

# Local dumps
*.local.json
*.local.md

# Compiled Windows wrappers (build locally with bun --compile)
claude-wrapper/*.exe
claude-wrapper/.*.bun-build
claude-wrapper/_wire-*.mjs

# Agent scratch (SDD / local tooling)
.superpowers/
